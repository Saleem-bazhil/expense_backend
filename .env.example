# ------------------------------------------------------------
# Django core
# ------------------------------------------------------------
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=replace-me-with-a-long-random-string
DJANGO_DEBUG=False
# Comma-separated hostnames only. Full URLs are also normalized automatically,
# but plain hostnames are still the safest choice in production.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,apiexpense.bazhilgroups.in
# Leave this off unless your proxy is known to send a single clean
# X-Forwarded-Host value. A bad forwarded host header causes Django 400s.
DJANGO_USE_X_FORWARDED_HOST=False
# Full origins (scheme + host). Required if your frontend posts to Django.
DJANGO_CSRF_TRUSTED_ORIGINS=https://apiexpense.bazhilgroups.in
DJANGO_TIME_ZONE=Asia/Kolkata
DJANGO_LOG_LEVEL=INFO

# HTTPS hardening (enable once TLS is confirmed working at the proxy)
DJANGO_SECURE_SSL_REDIRECT=False
DJANGO_SECURE_HSTS_SECONDS=0

# ------------------------------------------------------------
# CORS (frontend origins)
# ------------------------------------------------------------
CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOWED_ORIGINS=https://your-frontend.com

# ------------------------------------------------------------
# Database
# ------------------------------------------------------------
# Use SQLite by default. The database file will be created at /app/db.sqlite3
# inside the container (or in the project root when running locally).
DB_ENGINE=sqlite
# Optional PostgreSQL settings if you switch back later:
# DB_NAME=expense_tracker
# DB_USER=postgres
# DB_PASSWORD=change-me
# DB_HOST=postgres
# DB_PORT=5432
# DB_CONN_MAX_AGE=60

# ------------------------------------------------------------
# Optional: auto-create a superuser on first boot
# ------------------------------------------------------------
# DJANGO_SUPERUSER_USERNAME=admin
# DJANGO_SUPERUSER_EMAIL=admin@example.com
# DJANGO_SUPERUSER_PASSWORD=change-me
