# =============================================================================
# Backend environment template — copy to .env for local dev, or paste into
# Dokploy → backend service → Environment for production.
# All values are read at process start; restart the container after changes.
# =============================================================================

# ------------------------------------------------------------
# Django core
# ------------------------------------------------------------
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=replace-me-with-a-long-random-string

# Set to True ONLY for local dev. NEVER True in production.
DJANGO_DEBUG=False

# Comma-separated hostnames (no scheme, no port).
DJANGO_ALLOWED_HOSTS=apiexpense.bazhilgroups.in,localhost,127.0.0.1

# Comma-separated full origins (scheme + host). Required for any POST/PUT/DELETE
# coming from the browser (admin, DRF browsable API, your frontend).
DJANGO_CSRF_TRUSTED_ORIGINS=https://apiexpense.bazhilgroups.in

# Behind a reverse proxy (Dokploy/Traefik, nginx)? Leave True.
DJANGO_USE_X_FORWARDED_HOST=True

DJANGO_TIME_ZONE=Asia/Kolkata
DJANGO_LOG_LEVEL=INFO

# ------------------------------------------------------------
# HTTPS hardening — enable AFTER you've verified TLS works at the proxy.
# Turning these on too early causes redirect loops.
# ------------------------------------------------------------
DJANGO_SECURE_SSL_REDIRECT=False
# Once stable, ramp HSTS: 60 → 86400 → 31536000 (1 year)
DJANGO_SECURE_HSTS_SECONDS=0
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=True
DJANGO_SECURE_HSTS_PRELOAD=True

# ------------------------------------------------------------
# CORS (which browser origins may call this API)
# ------------------------------------------------------------
CORS_ALLOW_ALL_ORIGINS=False
# Add your production frontend domain(s) here, comma-separated.
# Local dev (Vite) origins are already whitelisted by default.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Regex matchers — default already covers ALL *.vercel.app preview + prod URLs.
# Override only if you need to restrict further or add another pattern.
# CORS_ALLOWED_ORIGIN_REGEXES=^https://([a-z0-9-]+\.)*vercel\.app$
CORS_ALLOW_CREDENTIALS=False

# ------------------------------------------------------------
# REST Framework
# ------------------------------------------------------------
DRF_PAGE_SIZE=50
DRF_THROTTLE_ANON=120/minute
DRF_THROTTLE_USER=600/minute

# ------------------------------------------------------------
# Database — defaults to SQLite (fine for low-traffic / single-instance).
# For Postgres, set DB_ENGINE=postgres and fill in the rest.
# ------------------------------------------------------------
DB_ENGINE=sqlite
# DB_ENGINE=postgres
# DB_NAME=expense_tracker
# DB_USER=postgres
# DB_PASSWORD=change-me
# DB_HOST=postgres
# DB_PORT=5432
# DB_CONN_MAX_AGE=60

# ------------------------------------------------------------
# Optional: auto-create a superuser on first boot (handy for fresh deploys)
# ------------------------------------------------------------
# DJANGO_SUPERUSER_USERNAME=admin
# DJANGO_SUPERUSER_EMAIL=admin@example.com
# DJANGO_SUPERUSER_PASSWORD=change-me-too
